#!/bin/bash
echo "<?xml version=\"1.0\" encoding=\"UTF-8\"?>"
echo "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">" 
for i in $(find * -type f -not -path '*/\.git/*')
do
	echo "	<url>"
	echo "		<loc>""$1"/$i"</loc>"
	echo "		<lastmod>"$(stat -c %y "$i" | sed 's/ .*//')"</lastmod>"
	echo "	</url>"
done
echo "</urlset>"
